# このファイルはキー名の雛形（値は空）。実際の値は .env.local に記入する（.env.local は gitignore 済み）。

# Anthropic Claude API（サーバー専用。絶対に NEXT_PUBLIC_ を付けない）
ANTHROPIC_API_KEY=

# Supabase（URL と anon/publishable key はクライアントに出してよい）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role（サーバー専用。クライアントに出さない）
SUPABASE_SERVICE_ROLE_KEY=
